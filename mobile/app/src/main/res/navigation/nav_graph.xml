<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.econetvision.erp.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/attendanceFragment"
        android:name="com.econetvision.erp.ui.attendance.AttendanceFragment"
        android:label="Attendance"
        tools:layout="@layout/fragment_attendance" />

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.econetvision.erp.ui.notifications.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.econetvision.erp.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">

        <action
            android:id="@+id/action_settingsFragment_to_employeesFragment"
            app:destination="@id/employeesFragment" />

        <action
            android:id="@+id/action_settingsFragment_to_workLocationsFragment"
            app:destination="@id/workLocationsFragment" />

        <action
            android:id="@+id/action_settingsFragment_to_usersFragment"
            app:destination="@id/usersFragment" />
    </fragment>

    <fragment
        android:id="@+id/employeesFragment"
        android:name="com.econetvision.erp.ui.employees.EmployeesFragment"
        android:label="Employees"
        tools:layout="@layout/fragment_employees" />

    <fragment
        android:id="@+id/workLocationsFragment"
        android:name="com.econetvision.erp.ui.locations.WorkLocationsFragment"
        android:label="Work Locations"
        tools:layout="@layout/fragment_work_locations" />

    <fragment
        android:id="@+id/usersFragment"
        android:name="com.econetvision.erp.ui.users.UsersFragment"
        android:label="Users"
        tools:layout="@layout/fragment_users" />
</navigation>
