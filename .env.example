# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://erp_user:erp_pass@localhost:5432/erp_db
SECRET_KEY=erp-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000

# ─── Twilio (Phone & Email Verification) ───────────────────────────────────
# Sign up at https://www.twilio.com/console
# Create a Verify Service at https://www.twilio.com/console/verify/services
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid_here

# ─── File storage (photos / logos) ─────────────────────────────────────────
# STORAGE_BACKEND=local  → files written to UPLOAD_ROOT.
#   For persistence on Railway, attach a Volume and mount it (e.g. /data), then
#   set UPLOAD_ROOT=/data/uploads. Without a volume the container filesystem is
#   ephemeral and uploaded images are wiped on every redeploy.
# STORAGE_BACKEND=s3     → files stored in an S3-compatible bucket (AWS S3,
#   Cloudflare R2, MinIO…). Survives redeploys and works across multiple instances.
STORAGE_BACKEND=local
UPLOAD_ROOT=
# --- S3 / R2 (only used when STORAGE_BACKEND=s3) ---
S3_BUCKET=
S3_ENDPOINT_URL=            # e.g. https://<account-id>.r2.cloudflarestorage.com (blank for AWS S3)
S3_REGION=auto             # e.g. us-east-1 for AWS
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: serve images directly from a public bucket / CDN instead of through
# the app. When set, the DB stores absolute URLs under this base.
S3_PUBLIC_BASE_URL=

# ─── KYC Provider ──────────────────────────────────────────────────────────
KYC_PROVIDER=manual
KYC_API_KEY=
KYC_API_SECRET=

# ─── Licensing ─────────────────────────────────────────────────────────────
# Static master license key. When set, the backend treats every company as
# licensed and does NOT call the external license server (offline bypass).
# In CI/CD this comes from the GitHub Actions secret LICENSE_KEY.
LICENSE_KEY=
# External license server that validates licenses and manages device seats.
LICENSE_SERVER_URL=
# Base path of the license server's public client API (validate/activate/…).
LICENSE_API_BASE=/api/v1
# Product identifier reported to the license server.
LICENSE_PRODUCT=erp
# Master switch — set to false to disable license enforcement entirely.
LICENSE_ENFORCE=true
# Send device/location/browser telemetry with each verification.
LICENSE_TELEMETRY_ENABLED=true
# Timeout (seconds) for calls to the external license server.
LICENSE_TIMEOUT_SECONDS=5
# Stable identifier for this ERP instance (optional; auto-derived if empty).
INSTANCE_ID=
